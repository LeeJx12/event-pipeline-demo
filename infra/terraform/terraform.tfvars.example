aws_region  = "ap-northeast-2"
environment = "dev"

# Never commit real passwords. Copy this file to terraform.tfvars locally.
db_username = "pipeline"
db_password = "CHANGE_ME_TO_A_LONG_DEV_PASSWORD"
db_name     = "pipeline"

# Use dev-latest after running ./scripts/ecr-build-push.sh.
# Or set to a git SHA tag, e.g. image_tag = "e917c5a".
image_tag = "dev-latest"

# W3-4 provisions a dev-only single-node Kafka on ECS/Fargate.
# Producer uses Cloud Map DNS generated by Terraform; this placeholder is kept for backward compatibility.
kafka_bootstrap_servers = "not-used-after-w3-4:9092"

kafka_image          = "bitnami/kafka:3.7.1"
kafka_cpu            = 1024
kafka_memory         = 2048
kafka_desired_count  = 1
kafka_num_partitions = 6
